# KelsAI Configuration — copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Gemini API Key  →  https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Alternative AI Provider ─────────────────────────────────────────
# OpenRouter API Key  →  https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_PROVIDER=gemini

# ── App Settings ──────────────────────────────────────────────────────────────
MIN_MATCH_SCORE=70
REFRESH_INTERVAL_HOURS=6

# ── Optional: JSearch via RapidAPI (Free — 200 req/month) ────────────────────
# Adds real LinkedIn + Indeed + Glassdoor jobs via a single clean API.
# Sign up FREE at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# ── Optional: Adzuna Jobs API (Free — 1000 req/month) ────────────────────────
# Excellent for India-specific tech job listings with salary data.
# Sign up FREE at: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
